# Copy to .env to override. Defaults run fully on mocks with zero setup.

# ---- providers / engines ----
EMAIL_PROVIDER=mock            # mock | graph
STORAGE_PROVIDER=local         # local | onedrive
EXTRACTION_ENGINE=mock         # mock | vision  (vision = YOUR real LLM)

# ---- database ----
# Default: SQLite (zero setup). For your production Postgres, uncomment:
# DATABASE_URL=postgresql+asyncpg://timesheet:timesheet@localhost:5432/timesheet_db
# (and uncomment asyncpg in requirements.txt)

# ---- real vision LLM (used when EXTRACTION_ENGINE=vision) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
EXTRACTION_MODEL=gpt-4o        # gpt-4o | gpt-4.1 | gpt-5.4 | gpt-4o-mini
VISION_IMAGE_DETAIL=high       # low | high
VALIDATION_MODEL=gpt-4o-mini   # text cross-check model
ENABLE_TEXT_VALIDATION=true
# Optional vLLM (Qwen etc.) for non-GPT EXTRACTION_MODEL:
VLLM_API_KEY=
VLLM_BASE_URL=https://myvllmserver.duckdns.org
VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ---- storage ----
# STORAGE_ROOT=/abs/path/to/storage

# ---- Microsoft Graph (EMAIL_PROVIDER=graph) ----
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=timesheets@yourcompany.com
GRAPH_FOLDER=Inbox
