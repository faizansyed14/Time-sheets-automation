# ============================================================================
# Timesheet Intelligence Portal — UNIVERSAL environment template
#
# THIS is the only env file shipped in git. Private copies (.env, .env.local,
# .env.dev, .env.prod) stay on your machine and are gitignored.
#
# Setup:
#   ./scripts/create-env.sh          # interactive: pick LOCAL / DEV / PROD → writes .env
#   ./scripts/create-env.sh LOCAL    # or pass a profile directly
#   ./scripts/create-env.sh DEV --force   # overwrite existing .env
# Then start:
#   ./scripts/local/start.sh | ./scripts/dev/start.sh | ./scripts/prod/start.sh
#
# Profiles (same keys; values differ) are the commented blocks below.
#
# Profiles (same keys everywhere; only values differ):
#   LOCAL  → docker-compose.local.yml   (Postgres + local disk in Docker)
#   DEV    → docker-compose.dev.yml     (AWS RDS + S3)
#   PROD   → docker-compose.prod.yml    (production; replace CHANGE_ME)
#
# Backend alone (no Docker): copy to backend/.env and use localhost hosts.
# ============================================================================

# ---- environment ----
ENVIRONMENT=dev                 # dev | prod | local

# ---- database (PostgreSQL only) ----
# Docker local/prod: host "db". AWS RDS: put the RDS endpoint in DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://timesheet:timesheet@localhost:5432/timesheet
POSTGRES_USER=timesheet
POSTGRES_PASSWORD=timesheet
POSTGRES_DB=timesheet
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# true = create missing tables on startup (quick local). Docker/RDS: false + Alembic.
AUTO_CREATE_TABLES=true

# ---- infrastructure ----
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CELERY_TASK_ALWAYS_EAGER=true   # true = run tasks inline (no worker needed)

# ---- concurrency (docker-compose.*.yml) ----
UVICORN_WORKERS=2
CELERY_CONCURRENCY=2

# Scheduled jobs (Celery beat), hours between pipeline-raw purges
PIPELINE_RAW_PURGE_INTERVAL_HOURS=24

# ---- auth / security ----
AUTH_ENABLED=true
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
ACCESS_TOKEN_TTL_MINUTES=480
LOGIN_TOKEN_TTL_MINUTES=10

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_EMAIL=admin@example.com

# OTP lifecycle
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=3
OTP_RESEND_COOLDOWN_SECONDS=30

# rate limiting (sliding window)
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW_SECONDS=300
OTP_VERIFY_RATE_MAX=20
OTP_VERIFY_RATE_WINDOW_SECONDS=300

# CAPTCHA issuance throttle
CAPTCHA_RATE_MAX=20
CAPTCHA_RATE_WINDOW_SECONDS=30

# CAPTCHA answer-verification throttle
CAPTCHA_VERIFY_RATE_MAX=20
CAPTCHA_VERIFY_RATE_WINDOW_SECONDS=300

# Authenticator (TOTP) verify throttle
TOTP_VERIFY_RATE_MAX=20
TOTP_VERIFY_RATE_WINDOW_SECONDS=300
TOTP_ISSUER=Timesheets

# captcha + fingerprint
CAPTCHA_LENGTH=6
CAPTCHA_TTL_SECONDS=180
FINGERPRINT_REQUIRED=true

# Pipeline retry copies — max age (days) for still-failed originals
PIPELINE_RAW_RETENTION_DAYS=60
# Where failed-file originals are kept for Retry.
#   STORAGE_PROVIDER=local → set a disk path (e.g. /app/storage/_pipeline-raw)
#   STORAGE_PROVIDER=s3    → leave EMPTY (copies live under S3_RAW_PREFIX on S3)
# Empty + local also falls back to backend default data/pipeline_raw.
PIPELINE_RAW_ROOT=

# ---- providers ----
EMAIL_PROVIDER=mock             # mock | graph
STORAGE_PROVIDER=local          # local | s3  (onedrive is a stub — do not use)
EXTRACTION_ENGINE=mock          # mock | vision

# ---- AI / extraction (.env only — Admin → Settings is read-only) ----
EXTRACTION_ENGINE=mock          # mock | vision
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_VISION_MODEL=gpt-4o
OPENAI_CLASSIFY_MODEL=gpt-4o-mini
EXTRACTION_MODEL=gpt-4o
VISION_IMAGE_DETAIL=high        # high | low — for scans/photos

# ---- cost / accuracy tuning ----
PDF_RENDER_DPI=150
VISION_JSON_MODE=true
OCR_PROVIDER=none               # none | tesseract

# Inbox sync throttle: at most one incremental Graph sync per N seconds; in
# between, the inbox list + search serve instantly from the local DB.
INBOX_SYNC_MIN_INTERVAL_SECONDS=60

# ---- AI data security ----
PII_REDACTION=true

# ---- agentic chat ----
AGENT_CHAT_MODEL=gpt-4o-mini

# ---- file storage (STORAGE_PROVIDER=s3) ----
S3_BUCKET=
S3_PREFIX=timesheets
S3_RAW_PREFIX=_pipeline-raw
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# ---- Microsoft Graph (EMAIL_PROVIDER=graph) ----
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
# Secret *Value* from Azure, NOT the Secret ID (UUID).
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=timesheets@yourcompany.com
GRAPH_FOLDER=Inbox
GRAPH_OTP_SENDER=timesheets@yourcompany.com

# ---- CORS ----
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]


