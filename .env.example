# ============================================================================
# Timesheet Intelligence Portal — environment configuration
#
# Docker (dev or prod):
#   cp .env.dev .env    # development
#   cp .env.prod .env   # production (replace CHANGE_ME secrets)
#
# Local backend only (no Docker):
#   cp .env.example backend/.env
# ============================================================================

# ---- environment ----
ENVIRONMENT=dev                 # dev | prod

# ---- database (PostgreSQL only) ----
# Docker uses the "db" service host. For AWS RDS just change the host:
#   DATABASE_URL=postgresql+asyncpg://USER:PASS@my-db.xxxx.rds.amazonaws.com:5432/timesheet
DATABASE_URL=postgresql+asyncpg://timesheet:timesheet@localhost:5432/timesheet
POSTGRES_USER=timesheet
POSTGRES_PASSWORD=timesheet
POSTGRES_DB=timesheet
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ---- infrastructure ----
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CELERY_TASK_ALWAYS_EAGER=true   # true = run tasks inline (no worker needed)

# ---- auth / security ----
AUTH_ENABLED=true
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
ACCESS_TOKEN_TTL_MINUTES=480
LOGIN_TOKEN_TTL_MINUTES=10

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_EMAIL=admin@example.com

# OTP lifecycle
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=3
OTP_RESEND_COOLDOWN_SECONDS=30

# rate limiting (sliding window)
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW_SECONDS=300
OTP_VERIFY_RATE_MAX=20
OTP_VERIFY_RATE_WINDOW_SECONDS=300

# captcha + fingerprint
CAPTCHA_LENGTH=6
CAPTCHA_TTL_SECONDS=180
FINGERPRINT_REQUIRED=true

# ---- AI / extraction (also editable from Admin → Settings) ----
EXTRACTION_ENGINE=mock          # mock | vision
EXTRACTION_MODEL=gpt-4o
VISION_IMAGE_DETAIL=high        # high | low
VALIDATION_MODEL=gpt-4o-mini
ENABLE_TEXT_VALIDATION=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Optional vLLM (Qwen etc.) for non-GPT EXTRACTION_MODEL:
VLLM_API_KEY=
VLLM_BASE_URL=https://myvllmserver.duckdns.org
VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ---- file storage ----
# local | s3 | onedrive. Switch to AWS S3 by setting STORAGE_PROVIDER=s3 below.
STORAGE_PROVIDER=local
# AWS S3 (only when STORAGE_PROVIDER=s3). Omit keys on EC2/ECS to use IAM role.
S3_BUCKET=
S3_PREFIX=timesheets
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# ---- Microsoft Graph (email reading + OTP delivery) ----
EMAIL_PROVIDER=mock             # mock | graph
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
# Secret *Value* from Azure, NOT the Secret ID (UUID).
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=
GRAPH_FOLDER=Inbox
GRAPH_OTP_SENDER=

# ---- CORS (frontend origins) ----
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
