# DEV example — copy to .env and edit:
#   cp .env.dev .env
#
# Postgres + Redis + Celery worker (see docker-compose.dev.yml). ENVIRONMENT=dev.
ENVIRONMENT=dev

# ---- database (compose service "db") ----
POSTGRES_USER=timesheet
POSTGRES_PASSWORD=timesheet
POSTGRES_DB=timesheet
DATABASE_URL=postgresql+asyncpg://timesheet:timesheet@db:5432/timesheet

# ---- infrastructure ----
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CELERY_TASK_ALWAYS_EAGER=false

# ---- auth / security ----
AUTH_ENABLED=true
JWT_SECRET=dev-secret-change-me-0123456789abcdef0123456789
ACCESS_TOKEN_TTL_MINUTES=480
LOGIN_TOKEN_TTL_MINUTES=10

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_EMAIL=admin@example.com

# OTP lifecycle
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=3
OTP_RESEND_COOLDOWN_SECONDS=30

# rate limiting
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW_SECONDS=300
OTP_VERIFY_RATE_MAX=20
OTP_VERIFY_RATE_WINDOW_SECONDS=300

# captcha + fingerprint
CAPTCHA_LENGTH=6
CAPTCHA_TTL_SECONDS=180
FINGERPRINT_REQUIRED=true

# ---- providers (mock = no external keys; flip to vision/graph + fill keys below) ----
EMAIL_PROVIDER=mock
STORAGE_PROVIDER=local
EXTRACTION_ENGINE=mock

# ---- AI / extraction ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
EXTRACTION_MODEL=gpt-4o
VISION_IMAGE_DETAIL=high
VALIDATION_MODEL=gpt-4o-mini
ENABLE_TEXT_VALIDATION=true

VLLM_API_KEY=
VLLM_BASE_URL=https://myvllmserver.duckdns.org
VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ---- Microsoft Graph (EMAIL_PROVIDER=graph) ----
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=
GRAPH_FOLDER=Inbox
GRAPH_OTP_SENDER=

# ---- CORS ----
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
