# ============================================================================
# Timesheet Intelligence Portal — environment configuration (dev Profile)
# ============================================================================

# ---- environment ----
ENVIRONMENT=dev                 # dev | prod

# ---- database (AWS RDS PostgreSQL — no local db container) ----
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@your-db.xxxxxxxx.us-east-1.rds.amazonaws.com:5432/timesheet
# Per-process pool. Total RDS connections ≈ UVICORN_WORKERS × (POOL_SIZE +
# MAX_OVERFLOW) + Celery. Keep the sum under your RDS max_connections
# (a db.t3.micro allows ~87). Defaults below: 4 × (5+5) = 40, leaving headroom.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
# Docker runs migrations via startup runner; auto create should be false
AUTO_CREATE_TABLES=false

# ---- infrastructure ----
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CELERY_TASK_ALWAYS_EAGER=false

# ---- concurrency tuning (read by docker-compose.dev.yml) ----
# Rule of thumb: UVICORN_WORKERS ≈ number of vCPUs. Raise for more parallel
# GET/API throughput; watch RAM (each worker loads the full app) + RDS conns.
UVICORN_WORKERS=2
CELERY_CONCURRENCY=2

# Scheduled background jobs (Celery beat) — change without touching code:
PIPELINE_RAW_PURGE_INTERVAL_HOURS=24
INBOX_AI_CHECK_INTERVAL_HOURS=5
INBOX_AI_CHECK_BATCH=100

# ---- auth / security ----
AUTH_ENABLED=true
JWT_SECRET=dev-secret-change-me-0123456789abcdef0123456789
ACCESS_TOKEN_TTL_MINUTES=480
LOGIN_TOKEN_TTL_MINUTES=10

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_EMAIL=admin@example.com

# OTP lifecycle
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=3
OTP_RESEND_COOLDOWN_SECONDS=30

# rate limiting (sliding window)
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW_SECONDS=300
OTP_VERIFY_RATE_MAX=20
OTP_VERIFY_RATE_WINDOW_SECONDS=300

# CAPTCHA issuance throttle
CAPTCHA_RATE_MAX=20
CAPTCHA_RATE_WINDOW_SECONDS=30

# CAPTCHA answer-verification throttle (brute-force guard)
CAPTCHA_VERIFY_RATE_MAX=20
CAPTCHA_VERIFY_RATE_WINDOW_SECONDS=300

# Authenticator (TOTP) verify throttle
TOTP_VERIFY_RATE_MAX=20
TOTP_VERIFY_RATE_WINDOW_SECONDS=300
TOTP_ISSUER=Timesheets

# captcha + fingerprint
CAPTCHA_LENGTH=6
CAPTCHA_TTL_SECONDS=180
FINGERPRINT_REQUIRED=true

# Pipeline retry copies: max retention age for raw files if retry keeps failing
PIPELINE_RAW_RETENTION_DAYS=60

# ---- providers ----
EMAIL_PROVIDER=mock
STORAGE_PROVIDER=s3
EXTRACTION_ENGINE=mock

# ---- AI / extraction (also editable from Admin → Settings) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
EXTRACTION_MODEL=gpt-4o
VISION_IMAGE_DETAIL=high
VALIDATION_MODEL=gpt-4o-mini
ENABLE_TEXT_VALIDATION=true

# ---- cost / accuracy tuning (also editable in Admin → AI Settings) ----
PDF_RENDER_DPI=150
VISION_ADAPTIVE_DETAIL=true
VISION_JSON_MODE=true
EXTRACTION_PREFER_DETERMINISTIC=false
OCR_PROVIDER=none

# Optional vLLM (Qwen etc.) for non-GPT EXTRACTION_MODEL:
VLLM_API_KEY=
VLLM_BASE_URL=https://myvllmserver.duckdns.org
VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ---- agentic layer (email→employee identity, pipeline fix-advisor) ----
AI_CHECK_MODEL=gpt-4o-mini
AGENT_CHAT_MODEL=gpt-4o-mini

# ---- file storage (AWS S3 — no local storage volume) ----
S3_BUCKET=your-timesheet-bucket
S3_PREFIX=timesheets
S3_RAW_PREFIX=_pipeline-raw
S3_REGION=us-east-1
# Leave both blank on EC2 (the instance IAM role is used automatically).
# Only set these if running outside AWS without a role (e.g. a laptop).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# ---- Microsoft Graph (email reading + OTP delivery) ----
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=timesheets@yourcompany.com
GRAPH_FOLDER=Inbox
GRAPH_OTP_SENDER=timesheets@yourcompany.com

# ---- CORS (frontend origins) ----
# The SPA is served by nginx on the same origin as the API (same-origin, so
# this mostly matters for direct API testing). Set to your EC2 IP/domain once
# deployed, e.g. ["http://<ec2-public-ip>"] or ["https://dev.yourcompany.com"].
CORS_ORIGINS=["http://localhost:8080"]
