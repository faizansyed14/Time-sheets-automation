# ============================================================================
# Timesheet Intelligence Portal — environment configuration (prod Profile)
# ============================================================================

# ---- environment ----
ENVIRONMENT=prod                 # dev | prod

# ---- database (PostgreSQL only) ----
DATABASE_URL=postgresql+asyncpg://timesheet:CHANGE_ME@db:5432/timesheet
POSTGRES_USER=timesheet
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=timesheet
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
AUTO_CREATE_TABLES=false

# ---- infrastructure ----
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CELERY_TASK_ALWAYS_EAGER=false

# Scheduled background jobs (Celery beat) — change without touching code:
PIPELINE_RAW_PURGE_INTERVAL_HOURS=24
INBOX_AI_CHECK_INTERVAL_HOURS=5
INBOX_AI_CHECK_BATCH=100

# ---- auth / security ----
AUTH_ENABLED=true
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_TTL_MINUTES=480
LOGIN_TOKEN_TTL_MINUTES=10

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_ME
DEFAULT_ADMIN_EMAIL=admin@yourcompany.com

# OTP lifecycle
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=3
OTP_RESEND_COOLDOWN_SECONDS=30

# rate limiting (sliding window)
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW_SECONDS=300
OTP_VERIFY_RATE_MAX=20
OTP_VERIFY_RATE_WINDOW_SECONDS=300

# CAPTCHA issuance throttle
CAPTCHA_RATE_MAX=20
CAPTCHA_RATE_WINDOW_SECONDS=30

# CAPTCHA answer-verification throttle (brute-force guard)
CAPTCHA_VERIFY_RATE_MAX=20
CAPTCHA_VERIFY_RATE_WINDOW_SECONDS=300

# Authenticator (TOTP) verify throttle
TOTP_VERIFY_RATE_MAX=20
TOTP_VERIFY_RATE_WINDOW_SECONDS=300
TOTP_ISSUER=Timesheets

# captcha + fingerprint
CAPTCHA_LENGTH=6
CAPTCHA_TTL_SECONDS=180
FINGERPRINT_REQUIRED=true

# Pipeline retry copies: max retention age for raw files if retry keeps failing
PIPELINE_RAW_RETENTION_DAYS=60

# ---- providers ----
EMAIL_PROVIDER=graph
STORAGE_PROVIDER=local
EXTRACTION_ENGINE=vision

# ---- AI / extraction (also editable from Admin → Settings) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
EXTRACTION_MODEL=gpt-4o
VISION_IMAGE_DETAIL=high
VALIDATION_MODEL=gpt-4o-mini
ENABLE_TEXT_VALIDATION=true

# ---- cost / accuracy tuning (also editable in Admin → AI Settings) ----
PDF_RENDER_DPI=150
VISION_ADAPTIVE_DETAIL=true
VISION_JSON_MODE=true
EXTRACTION_PREFER_DETERMINISTIC=false
OCR_PROVIDER=none

# Optional vLLM (Qwen etc.) for non-GPT EXTRACTION_MODEL:
VLLM_API_KEY=
VLLM_BASE_URL=https://myvllmserver.duckdns.org
VLLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ---- agentic layer (email→employee identity, pipeline fix-advisor) ----
AI_CHECK_MODEL=gpt-4o-mini
AGENT_CHAT_MODEL=gpt-4o-mini

# ---- file storage ----
S3_BUCKET=
S3_PREFIX=timesheets
S3_RAW_PREFIX=_pipeline-raw
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# ---- Microsoft Graph (email reading + OTP delivery) ----
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=timesheets@yourcompany.com
GRAPH_FOLDER=Inbox
GRAPH_OTP_SENDER=timesheets@yourcompany.com

# ---- CORS (frontend origins) ----
CORS_ORIGINS=["https://your-domain.com"]
